{
  "default": {
    "paths": ["src/test/features/**/*.feature"],
    "import": [
      "src/support/**/*.ts",
      "src/hooks/**/*.ts",
      "src/test/step-definitions/**/*.ts"
    ],
    "require": [],
    "formatOptions": {
      "snippetInterface": "async-await"
    },
    "publishQuiet": true,
    "format": [
      "progress",
      "json:reports/cucumber/report.json",
      "html:reports/cucumber-report.html"
    ]
  }
}
